---
const contacts = [
  { label: "email", value: "rhczs6bz4d@privaterelay.appleid.com", url: "mailto:rhczs6bz4d@privaterelay.appleid.com", external: false },
  { label: "github", value: "Chris0x88", url: "https://github.com/Chris0x88", external: true },
  { label: "hugging face", value: "Chris0x88", url: "https://huggingface.co/Chris0x88", external: true },
  { label: "x / twitter", value: "@chris0x88", url: "https://x.com/chris0x88", external: true }
];
---

<section id="contact" class="max-w-6xl mx-auto px-6 py-40 relative">
  <div class="relative z-10 max-w-4xl">
    <span class="text-[10px] font-black text-accent tracking-[0.3em] uppercase opacity-90">EXTERNAL_COMMS // LINK_ESTABLISHED</span>
    <h2 class="text-5xl md:text-7xl font-black font-outfit mb-8 text-white tracking-tighter leading-none uppercase">Contact.</h2>
    <p class="text-white text-2xl leading-tight mb-16 font-black max-w-2xl uppercase">
      Strategic advisory, technical collaboration, and deep builds.
      <br/> <span class="text-accent underline decoration-4 underline-offset-8">[PRODUCTION_GRADE_ONLY]</span>
    </p>

    <div class="grid sm:grid-cols-2 gap-6">
      {contacts.map(contact => (
        <a href={contact.url} target={contact.external ? "_blank" : undefined} class="dashboard-card p-10 flex items-center justify-between group">
          <div class="corner-marker marker-tl opacity-40 group-hover:opacity-100 transition-opacity"></div>
          <div>
            <div class="mono text-[10px] text-accent font-black uppercase mb-3 tracking-[0.2em]">{contact.label}_PORT</div>
            <div class="font-black text-2xl text-white tracking-tight">{contact.value}</div>
          </div>
          <span class="text-3xl text-accent group-hover:translate-x-1 transition-all duration-300">
            {contact.external ? "↗" : "→"}
          </span>
        </a>
      ))}
    </div>
  </div>
</section>
