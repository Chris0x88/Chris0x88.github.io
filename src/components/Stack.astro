---
const stack = [
  { category: "languages", items: "Python · TypeScript · Bash" },
  { category: "ai / agents", items: "Claude Code · OpenClaw · LangGraph · prompt specs" },
  { category: "chains", items: "Hedera · Hyperliquid · SaucerSwap" },
  { category: "backend", items: "FastAPI · SQLite · Postgres · Redis" },
  { category: "infra", items: "Docker · self-hosted · edge compute" },
  { category: "frontend", items: "Astro · Tailwind · vanilla when it's enough" },
  { category: "tooling", items: "pytest · ruff · gh actions · makefiles" },
  { category: "mindset", items: "Ship. Measure. Iterate. Repeat." }
];
---

<section id="stack" class="max-w-6xl mx-auto px-6 py-32">
  <div class="flex flex-col mb-16">
    <span class="text-[10px] font-black text-cyan-400 tracking-[0.3em] uppercase opacity-70">TECHNOLOGY_MATRIX //</span>
    <h2 class="text-4xl md:text-5xl font-black font-outfit text-white uppercase tracking-tighter leading-none">The Toolbox.</h2>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
    {stack.map(item => (
      <div class="dashboard-card p-10 group">
        <div class="corner-marker marker-tl opacity-40 group-hover:opacity-100 transition-opacity"></div>
        <div class="text-accent mono text-[10px] font-black mb-6 tracking-widest uppercase">CAT:_{item.category}</div>
        <div class="text-white text-base font-black leading-relaxed tracking-tight">{item.items}</div>
      </div>
    ))}
  </div>
</section>
