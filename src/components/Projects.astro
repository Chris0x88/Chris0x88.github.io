---
import { getCollection } from 'astro:content';
import ProjectCard from './ProjectCard.astro';

const projects = await getCollection('projects');
const sortedProjects = projects.sort((a, b) => a.data.order - b.data.order);
---

<section id="work" class="max-w-6xl mx-auto px-6 py-24">
  <div class="flex flex-col md:flex-row md:items-end justify-between mb-12 gap-4">
    <div>
      <p class="mono text-xs accent-text mb-2 uppercase tracking-widest">// flagship projects</p>
      <h2 class="text-4xl font-bold outfit">Things I've shipped</h2>
    </div>
    <a href="https://github.com/Chris0x88?tab=repositories" target="_blank" class="text-sm text-mute hover:text-accent transition-colors duration-200 mono">
      All repositories ↗
    </a>
  </div>

  <div class="grid md:grid-cols-2 gap-8">
    {sortedProjects.map(async (project) => {
      const { Content } = await project.render();
      return (
        <ProjectCard 
          title={project.data.title}
          tagline={project.data.tagline}
          status={project.data.status}
          github={project.data.github}
          tags={project.data.tags}
        >
          <Content />
        </ProjectCard>
      );
    })}
  </div>
</section>

<style>
  .outfit { font-family: 'Outfit', sans-serif; }
</style>
